# Copy this file to .env.docker before running Docker Compose.
# This setup uses your existing Neon database. It does not start a local database container.

# Backend runtime
SPRING_DATASOURCE_URL=jdbc:postgresql://your-neon-host/your-database?sslmode=require
SPRING_DATASOURCE_USERNAME=your_neon_username
SPRING_DATASOURCE_PASSWORD=your_neon_password
JWT_SIGNING_KEY=replace_with_a_long_random_secret

# Backend integrations
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_FROM=your_from_address

# Backend URLs/origins used by Docker
FRONTEND_URL=http://localhost:3000
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend build/runtime
# Browser-facing URLs use localhost because the browser is outside the Docker network.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=http://localhost:8080/ws
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# Server-side Next.js rewrites use the Compose service name inside the Docker network.
SERVER_API_URL=http://server:8080
